{
  "Cors": {
    "PolicyName": "Frontend",
    "AllowedOrigins": [
      "https://www.coffeecodex.my"
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "CoffeeCodex.API"
  },
  "Auth0": {
    "Domain": "your-auth0-domain",
    "Audience": "your-auth0-audience",
    "ClientId": "your-auth0-client-id",
    "ClientSecret": "your-auth0-client-secret"
  },
  "Persistence": {
    "UseInMemory": false,
    "InMemoryDatabaseName": "coffee-codex",
    "SeedOnStartup": false
  },
  "ConnectionStrings": {
    "PostgreSql": "Host=your-db-host;Port=5432;Database=coffee_codex;Username=your-db-user;Password=your-db-password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}