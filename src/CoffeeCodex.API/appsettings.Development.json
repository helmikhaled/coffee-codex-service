{
  "Cors": {
    "PolicyName": "FrontendDevelopment",
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://127.0.0.1:4200",
      "https://127.0.0.1:4200"
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "CoffeeCodex.API"
  },
  "Auth0": {
    "Domain": "dev-your-auth0-domain",
    "Audience": "dev-your-auth0-audience",
    "ClientId": "dev-your-auth0-client-id",
    "ClientSecret": "dev-your-auth0-client-secret"
  },
  "Persistence": {
    "UseInMemory": false,
    "InMemoryDatabaseName": "coffee-codex-dev",
    "SeedOnStartup": true
  },
  "ConnectionStrings": {
    "PostgreSql": "Host=localhost;Port=5432;Database=coffee_codex_dev;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
